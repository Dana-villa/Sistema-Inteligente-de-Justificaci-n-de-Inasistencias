    {
      "parameters": {
        "jsCode": "const rows = items.map(item => item.json);\n\nconst now = new Date();\n\nconst startOfWeek = new Date(now);\nstartOfWeek.setDate(now.getDate() - now.getDay() + 1);\nstartOfWeek.setHours(0,0,0,0);\n\nconst endOfWeek = new Date(startOfWeek);\nendOfWeek.setDate(startOfWeek.getDate() + 6);\nendOfWeek.setHours(23,59,59,999);\n\nconst weeklyRows = rows.filter(row => {\n  const fecha = new Date(row.Fecha_Registro);\n  return fecha >= startOfWeek && fecha <= endOfWeek;\n});\n\nconst total = weeklyRows.length;\nconst validas = weeklyRows.filter(r => r.Clasificacion_IA === 'VALIDA').length;\nconst invalidas = weeklyRows.filter(r => r.Clasificacion_IA === 'INVALIDA').length;\n\nreturn [{\n  json: {\n    total,\n    validas,\n    invalidas\n  }\n}];;"
      },
